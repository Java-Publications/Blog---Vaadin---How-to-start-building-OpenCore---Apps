# ── Maven ──────────────────────────────────────────────────────────
target/
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
buildNumber.properties
.mvn/timing.properties

# Maven wrapper: the properties file IS committed; we use
# distributionType=only-script so no jar is ever downloaded locally.
!**/mvnw
!**/mvnw.cmd
!**/.mvn/wrapper/maven-wrapper.properties
!**/.mvn/wrapper/maven-wrapper.jar

# ── Java build output ──────────────────────────────────────────────
*.class
*.log
hs_err_pid*
replay_pid*

# Compiled archives — none of these should be in source control.
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# ── Vaadin Flow / npm / Vite ───────────────────────────────────────
# All of these are regenerated by vaadin-maven-plugin's
# prepare-frontend / build-frontend goals on every build.
node/
node_modules/
**/package.json
**/package-lock.json
**/pnpm-lock.yaml
**/yarn.lock
**/tsconfig.json
**/tsconfig.tsbuildinfo
**/types.d.ts
**/vite.config.ts
**/vite.generated.ts
**/webpack.config.js
**/webpack.generated.js

# Generated Vaadin frontend resources.
**/src/main/frontend/generated/
**/src/main/frontend/index.html
**/src/main/bundles/

# ── macOS ──────────────────────────────────────────────────────────
.DS_Store
__MACOSX/

# ── IntelliJ IDEA ──────────────────────────────────────────────────
.idea/
*.iml
*.iws
*.ipr
out/
cmake-build-*/

# ── Eclipse ────────────────────────────────────────────────────────
.classpath
.project
.metadata
.settings/
.factorypath
.apt_generated/
.apt_generated_test/
bin/
tmp/

# ── NetBeans ───────────────────────────────────────────────────────
nbproject/private/
build/
nbbuild/
dist/
nbdist/
.nb-gradle/

# ── VS Code ────────────────────────────────────────────────────────
.vscode/

# ── Editor backups ─────────────────────────────────────────────────
*.swp
*.swo
*.bak
*~
*~.nib

# ── Environment / secrets ──────────────────────────────────────────
.env
.env.local
.env.*.local
*.token
secrets.properties

# ── Test / coverage scratch ───────────────────────────────────────
# Already covered by target/, listed for clarity.
# target/surefire-reports/
# target/pit-reports/
.scannerwork/

# ── Claude / agent scratch ────────────────────────────────────────
# Stays out of the repo; documented in .claude/CLAUDE.md if needed.
.claude/

# ── Local documentation drafts ────────────────────────────────────
# Internal notes that are not part of the public repo.
_docs/
